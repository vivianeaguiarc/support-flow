# =============================================================================
# SupportFlow Backend — Environment variables
# Copy this file to .env and adjust values for your environment.
# Never commit .env with real secrets.
# =============================================================================

# --- Application ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
# trace | debug | info | warn | error | fatal

# --- Database ---
# Local Docker Compose exposes Postgres on port 5433
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/supportflow?schema=public

# Integration tests only (optional)
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5433/supportflow_test?schema=public

# --- Authentication (JWT) ---
# Use at least 32 characters in production
JWT_SECRET=change-this-secret-in-production-min-32-chars
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# --- Security ---
CORS_ORIGIN=http://localhost:5173

# --- Rate limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=20
TICKET_CREATE_RATE_LIMIT_WINDOW_MS=900000
TICKET_CREATE_RATE_LIMIT_MAX_REQUESTS=30
ATTACHMENT_UPLOAD_RATE_LIMIT_WINDOW_MS=900000
ATTACHMENT_UPLOAD_RATE_LIMIT_MAX_REQUESTS=20
API_KEY_RATE_LIMIT_WINDOW_MS=900000
API_KEY_RATE_LIMIT_MAX_REQUESTS=10
WEBHOOK_RATE_LIMIT_WINDOW_MS=900000
WEBHOOK_RATE_LIMIT_MAX_REQUESTS=15
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCK_DURATION_MS=900000

# --- File uploads ---
UPLOAD_MAX_SIZE_MB=10
UPLOAD_DIR=storage/attachments

# --- API documentation ---
# Enabled by default (set SWAGGER_ENABLED=false to disable)
# SWAGGER_ENABLED=true

# --- Email notifications ---
# Disabled by default in local development
EMAIL_ENABLED=false
EMAIL_PROVIDER=smtp
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=supportflow@localhost

# --- Queue / Redis (BullMQ) ---
# Disabled by default in local development — jobs run inline synchronously
QUEUE_ENABLED=false
QUEUE_WORKERS_ENABLED=true
REDIS_URL=redis://localhost:6379
QUEUE_DEFAULT_ATTEMPTS=5
QUEUE_BACKOFF_DELAY_MS=1000
QUEUE_WORKER_CONCURRENCY=5
QUEUE_JOB_TIMEOUT_MS=300000

# --- Backup & Disaster Recovery (used by scripts/backup/*, not the app) ---
# Gate that must be 'true' for scripts/backup/backup-postgres.sh to run.
BACKUP_ENABLED=false
# Connection string used by pg_dump/pg_restore. Falls back to DATABASE_URL.
# BACKUP_DATABASE_URL=postgresql://user:pass@host:5432/supportflow
# Local directory where compressed dumps are written (default: ./backups).
BACKUP_OUTPUT_DIR=backups
# Dumps older than this many days are pruned after each backup (0 disables).
BACKUP_RETENTION_DAYS=7

# --- Observability (OpenTelemetry + Prometheus) ---
# OTEL_ENABLED=false
# OTEL_SERVICE_NAME=supportflow-backend
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# METRICS_ENABLED=true

# --- Demo seed (optional — run manually with pnpm db:seed) ---
# SEED_DEMO_ENABLED=false
# SEED_DEMO_PASSWORD=DemoSupport123!
# SEED_DEMO_ADMIN_EMAIL=admin.demo@supportflow.com
# SEED_DEMO_AGENT_EMAIL=agent.demo@supportflow.com
# SEED_DEMO_CUSTOMER_USER_EMAIL=customer.demo@supportflow.com
# SEED_DEMO_CUSTOMER_EMAIL=customer.demo@supportflow.com
# SEED_DEMO_TENANT_SLUG=demo
# SEED_DEMO_DEFAULT_SLA_HOURS=72

# =============================================================================
# Production checklist (set in your hosting provider, not in this file):
# - NODE_ENV=production
# - DATABASE_URL=<managed-postgres-url>
# - JWT_SECRET=<strong-random-secret-32+>
# - JWT_REFRESH_SECRET=<strong-random-secret-32+> (when refresh tokens ship)
# - CORS_ORIGIN=https://your-frontend-domain.com
# - LOG_LEVEL=info
# - SWAGGER_ENABLED=true (or false to disable docs in production)
# - RATE_LIMIT_ENABLED=true
# =============================================================================
DATABASE_URL="postgresql://neondb_owner:npg_1tcNV2FCZiTJ@ep-winter-water-atsebne7-pooler.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"