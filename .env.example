# =============================================================================
# SupportFlow Backend — Environment variables
# Copy this file to .env and adjust values for your environment.
# Never commit .env with real secrets.
# =============================================================================

# --- Application ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
# trace | debug | info | warn | error | fatal

# --- Database ---
# Local Docker Compose exposes Postgres on port 5433
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/supportflow?schema=public

# Integration tests only (optional)
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5433/supportflow_test?schema=public

# --- Authentication (JWT) ---
# Use at least 32 characters in production
JWT_SECRET=change-this-secret-in-production-min-32-chars
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# --- Security ---
CORS_ORIGIN=http://localhost:5173

# --- Rate limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=20

# --- File uploads ---
UPLOAD_MAX_SIZE_MB=10
UPLOAD_DIR=storage/attachments

# --- API documentation ---
# Enabled by default (set SWAGGER_ENABLED=false to disable)
# SWAGGER_ENABLED=true

# --- Email notifications ---
# Disabled by default in local development
EMAIL_ENABLED=false
EMAIL_PROVIDER=smtp
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=supportflow@localhost

# --- Demo seed (optional — run manually with pnpm db:seed) ---
# SEED_DEMO_ENABLED=false
# SEED_DEMO_PASSWORD=DemoSupport123!
# SEED_DEMO_ADMIN_EMAIL=admin.demo@supportflow.com
# SEED_DEMO_AGENT_EMAIL=agent.demo@supportflow.com
# SEED_DEMO_CUSTOMER_USER_EMAIL=customer.demo@supportflow.com
# SEED_DEMO_CUSTOMER_EMAIL=customer.demo@supportflow.com
# SEED_DEMO_TENANT_SLUG=demo
# SEED_DEMO_DEFAULT_SLA_HOURS=72

# =============================================================================
# Production checklist (set in your hosting provider, not in this file):
# - NODE_ENV=production
# - DATABASE_URL=<managed-postgres-url>
# - JWT_SECRET=<strong-random-secret-32+>
# - JWT_REFRESH_SECRET=<strong-random-secret-32+> (when refresh tokens ship)
# - CORS_ORIGIN=https://your-frontend-domain.com
# - LOG_LEVEL=info
# - SWAGGER_ENABLED=true (or false to disable docs in production)
# - RATE_LIMIT_ENABLED=true
# =============================================================================
