{
  "name": "@supportflow/sdk",
  "version": "1.0.0",
  "description": "Typed TypeScript SDK for the SupportFlow API, generated from OpenAPI.",
  "type": "module",
  "license": "ISC",
  "author": "Viviane Aguiar (https://vivianeaguiardev.com.br)",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  }
}
