# =============================================================================
# SupportFlow Backend — Production environment variables
# Copy to your hosting provider's secret manager / env panel.
# NEVER commit real secrets to version control.
# =============================================================================

# --- Application ---
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# --- Database (managed PostgreSQL — not localhost) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public&sslmode=require

# --- Authentication (JWT) — use cryptographically random strings (32+ chars) ---
JWT_SECRET=replace-with-strong-random-secret-at-least-32-characters
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=replace-with-strong-random-refresh-secret-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# --- Security ---
CORS_ORIGIN=https://your-frontend-domain.com

# --- Rate limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=20

# --- File uploads (mount a persistent volume at this path in Docker) ---
UPLOAD_MAX_SIZE_MB=10
UPLOAD_DIR=storage/attachments

# --- API documentation ---
# Swagger is enabled by default. Set to false to disable in production.
SWAGGER_ENABLED=true

# --- Optional: skip migrations in container start (if platform runs them separately) ---
# SKIP_MIGRATIONS=false

# =============================================================================
# Health checks (configure in your platform):
# - Liveness:  GET /health
# - Readiness: GET /health/ready  (includes database connectivity)
# =============================================================================
