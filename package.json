{
  "name": "supportflow-backend",
  "version": "1.0.0",
  "description": "SupportFlow API backend",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "start:prod": "node dist/server.js",
    "start:docker": "sh scripts/docker-entrypoint.sh",
    "migrate:deploy": "prisma migrate deploy",
    "docker:build": "docker build -t supportflow-backend .",
    "docker:run": "docker run --rm -p 3000:3000 supportflow-backend",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prisma:validate": "prisma validate",
    "env:check": "node --import tsx -e \"import './src/config/env.ts'; console.log('Environment configuration is valid')\"",
    "openapi:export": "tsx scripts/openapi/export-openapi.ts",
    "openapi:validate": "tsx scripts/openapi/validate-openapi.ts",
    "openapi:diff": "tsx scripts/openapi/diff-openapi.ts",
    "contract:check": "pnpm openapi:export && pnpm openapi:validate && pnpm openapi:diff",
    "contract:baseline": "pnpm openapi:export && cp docs/openapi.json docs/openapi.baseline.json",
    "smoke:test": "tsx scripts/smoke-test.ts",
    "smoke:test:staging": "SMOKE_BASE_URL=https://supportflow-api-staging.onrender.com tsx scripts/smoke-test.ts",
    "smoke:test:production": "SMOKE_BASE_URL=https://support-flow-uath.onrender.com tsx scripts/smoke-test.ts",
    "sdk:generate": "pnpm openapi:export && openapi-typescript docs/openapi.json -o packages/sdk/src/generated/openapi.types.ts",
    "sdk:build": "pnpm --filter @supportflow/sdk build",
    "sdk:verify": "pnpm sdk:generate && pnpm --filter @supportflow/sdk typecheck && pnpm sdk:build && git diff --exit-code -- docs/openapi.json packages/sdk/src/generated/openapi.types.ts",
    "ci:check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm prisma:validate && pnpm prisma:generate && pnpm contract:check && pnpm sdk:verify && pnpm test && pnpm build",
    "ci:integration": "pnpm prisma:generate && pnpm prisma:deploy && pnpm test:integration",
    "ci:full": "pnpm ci:check && pnpm test:db:prepare && pnpm ci:integration",
    "prepare": "husky",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:seed": "tsx prisma/seed.ts",
    "seed": "tsx prisma/seed.ts",
    "db:reset:demo": "tsx prisma/reset-demo.ts",
    "db:backup": "bash scripts/backup/backup-postgres.sh",
    "db:restore": "bash scripts/backup/restore-postgres.sh",
    "db:backup:verify": "bash scripts/backup/verify-backup.sh",
    "seed:staging": "SEED_DEMO_ENABLED=true NODE_ENV=production tsx prisma/seed.ts",
    "validate:staging": "bash scripts/validate-staging.sh",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "test:db:prepare": "docker compose up -d && node --import tsx src/test/integration/prepare-database.ts",
    "test": "vitest run --exclude '**/*.integration.spec.ts'",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest --exclude '**/*.integration.spec.ts'",
    "test:coverage": "vitest run --coverage"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [],
  "author": "Viviane Aguiar (https://vivianeaguiardev.com.br)",
  "license": "ISC",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.9",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "openapi-typescript": "^7.13.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/instrumentation-express": "^0.67.0",
    "@opentelemetry/instrumentation-http": "^0.219.0",
    "@opentelemetry/instrumentation-ioredis": "^0.67.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/instrumentation": "^7.8.0",
    "@types/multer": "^2.1.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "marked": "^18.0.5",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.1",
    "openapi-fetch": "^0.17.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prisma": "^7.8.0",
    "prom-client": "^15.1.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  }
}
