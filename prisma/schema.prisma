generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  SUPERVISOR
  AGENT
  CUSTOMER
  OMBUDSMAN
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  ESCALATED
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketHistoryEvent {
  CREATED
  STATUS_CHANGED
  PRIORITY_CHANGED
  ASSIGNED
  REASSIGNED
  CATEGORY_CHANGED
  COMMENT_ADDED
  ATTACHMENT_ADDED
  ATTACHMENT_REMOVED
  TICKET_ESCALATED
  SLA_BREACHED
}

enum CommentVisibility {
  INTERNAL
}

enum NotificationType {
  TICKET_CREATED
  TICKET_ASSIGNED
  TICKET_STATUS_CHANGED
  TICKET_COMMENT_ADDED
  TICKET_ATTACHMENT_ADDED
  SLA_WARNING
  SLA_EXPIRED
}

enum KnowledgeArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Tenant {
  id               String   @id @default(uuid())
  name             String
  slug             String   @unique
  isActive         Boolean  @default(true)
  defaultSlaHours  Int      @default(72)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users         User[]
  customers     Customer[]
  categories    TicketCategory[]
  tickets       Ticket[]
  histories     TicketHistory[]
  comments      TicketComment[]
  attachments   TicketAttachment[]
  notifications     Notification[]
  knowledgeArticles KnowledgeArticle[]

  @@map("tenants")
}

model User {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  email     String
  password  String
  role      UserRole @default(AGENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  ticketsAssigned   Ticket[]           @relation("TicketAssignee")
  ticketHistory     TicketHistory[]    @relation("TicketHistoryActor")
  ticketComments    TicketComment[]    @relation("CommentAuthor")
  ticketAttachments TicketAttachment[] @relation("AttachmentUploader")
  notifications     Notification[]     @relation("NotificationRecipient")
  refreshTokens       RefreshToken[]
  knowledgeArticles KnowledgeArticle[] @relation("KnowledgeArticleAuthor")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model Customer {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  email     String
  phone     String?
  document  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  tickets Ticket[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("customers")
}

model TicketCategory {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  slaHours    Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  tickets Ticket[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("ticket_categories")
}

model Ticket {
  id           String         @id @default(uuid())
  tenantId     String
  protocol     String
  title        String
  description  String
  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(MEDIUM)
  categoryId   String?
  customerId   String
  assignedToId String?
  slaDueAt     DateTime?
  closedAt     DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant        Tenant             @relation(fields: [tenantId], references: [id])
  customer      Customer           @relation(fields: [customerId], references: [id])
  category      TicketCategory?    @relation(fields: [categoryId], references: [id])
  assignedTo    User?              @relation("TicketAssignee", fields: [assignedToId], references: [id])
  history       TicketHistory[]
  comments      TicketComment[]
  attachments   TicketAttachment[]
  notifications Notification[]

  @@unique([tenantId, protocol])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, slaDueAt])
  @@index([tenantId, priority])
  @@index([status])
  @@index([priority])
  @@index([customerId])
  @@index([assignedToId])
  @@index([categoryId])
  @@map("tickets")
}

model TicketHistory {
  id          String             @id @default(uuid())
  tenantId    String
  ticketId    String
  event       TicketHistoryEvent
  field       String?
  oldValue    String?
  newValue    String?
  changedById String?
  metadata    Json?
  createdAt   DateTime           @default(now())

  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  ticket    Ticket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  changedBy User?   @relation("TicketHistoryActor", fields: [changedById], references: [id])

  @@index([tenantId])
  @@index([ticketId])
  @@index([changedById])
  @@map("ticket_histories")
}

model TicketComment {
  id         String            @id @default(uuid())
  tenantId   String
  ticketId   String
  authorId   String
  content    String
  visibility CommentVisibility @default(INTERNAL)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User   @relation("CommentAuthor", fields: [authorId], references: [id])

  @@index([tenantId])
  @@index([ticketId])
  @@index([authorId])
  @@map("ticket_comments")
}

model TicketAttachment {
  id           String   @id @default(uuid())
  tenantId     String
  ticketId     String
  uploadedById String
  fileName     String
  originalName String
  mimeType     String
  size         BigInt
  storagePath  String
  createdAt    DateTime @default(now())

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  ticket     Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedBy User   @relation("AttachmentUploader", fields: [uploadedById], references: [id])

  @@index([tenantId])
  @@index([ticketId])
  @@index([uploadedById])
  @@map("ticket_attachments")
}

model Notification {
  id          String           @id @default(uuid())
  tenantId    String
  recipientId String
  ticketId    String
  type        NotificationType
  title       String
  message     String
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  recipient User   @relation("NotificationRecipient", fields: [recipientId], references: [id])
  ticket    Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([recipientId])
  @@index([ticketId])
  @@index([readAt])
  @@map("notifications")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tenantId  String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model KnowledgeArticle {
  id          String                 @id @default(uuid())
  tenantId    String
  title       String
  slug        String
  content     String
  status      KnowledgeArticleStatus @default(DRAFT)
  category    String
  authorId    String
  publishedAt DateTime?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  author User   @relation("KnowledgeArticleAuthor", fields: [authorId], references: [id])

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, category])
  @@index([authorId])
  @@map("knowledge_articles")
}
